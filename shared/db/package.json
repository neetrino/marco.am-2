{
  "name": "@white-shop/db",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "types": "index.ts",
  "exports": {
    ".": "./index.ts",
    "./prisma": "./prisma.ts"
  },
  "scripts": {
    "db:generate": "prisma generate && node scripts/copy-prisma-schema-to-generated.cjs && node ../../scripts/verify-prisma-engine.js",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:seed:apple": "node prisma/seed-apple-product.cjs",
    "postinstall": "pnpm run db:generate"
  },
  "prisma": {
    "seed": "node prisma/seed.cjs"
  },
  "dependencies": {
    "@prisma/client": "^5.9.0",
    "prisma": "^5.9.0"
  }
}

