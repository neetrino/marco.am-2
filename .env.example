# =============================================================================
# Shop Marco — environment template
# Copy to `.env` locally. For staging/production, set the same keys in the host
# (e.g. Vercel Project → Settings → Environment Variables) per environment.
# =============================================================================

# -----------------------------------------------------------------------------
# Core runtime
# -----------------------------------------------------------------------------
# NODE_ENV is set by the toolchain (e.g. `development` for `next dev`, `production` for `next build` / Vercel).
# APP_ENV — optional override for logical tier when NODE_ENV alone is not enough (e.g. self-hosted).
#   development | staging | production  (aliases: dev, stage, prod)
# VERCEL_ENV — injected on Vercel: development | preview | production (preview → staging tier in code).
APP_ENV=""
# Public browser URL (trailing slash optional). Required for canonical links and client API base when split.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Server-only canonical URL fallback (used if NEXT_PUBLIC_APP_URL is unset on the server).
APP_URL="http://localhost:3000"
# If the API is on a different origin than the storefront, set explicitly (middleware CORS).
# CORS_ORIGIN="https://api.example.com"
# Optional: explicit API base for clients when not same-origin (see `src/lib/api-client.ts`).
NEXT_PUBLIC_API_URL=""


# -----------------------------------------------------------------------------
# Local development (pnpm dev)
# -----------------------------------------------------------------------------
# Use a local or Neon dev database. Do not use production DB credentials here.
NODE_ENV="development"


# -----------------------------------------------------------------------------
# Staging (e.g. Vercel Preview, or a dedicated host)
# -----------------------------------------------------------------------------
# Use a separate DATABASE_URL and secrets from production.
# On Vercel Preview, VERCEL_ENV=preview — the app maps this to "staging" unless APP_ENV is set.
# Set NEXT_PUBLIC_APP_URL to your preview domain if stable (e.g. branch URL or custom preview domain).


# -----------------------------------------------------------------------------
# Production
# -----------------------------------------------------------------------------
# NODE_ENV=production on the server; set strong JWT_SECRET, DATABASE_URL, and NEXT_PUBLIC_APP_URL to the live domain.


# ——— Database (Neon PostgreSQL) ———
# App traffic: use the *pooled* host (…-pooler…). Prisma merges sslmode, pgbouncer, pool_timeout, connection_limit at runtime.
# Optional: PRISMA_CONNECTION_LIMIT="1" for strict serverless (default: 5 in dev, 3 in production).
# Optional: NEON_CONNECT_TIMEOUT_SEC (seconds) — after Neon wakes from idle, raise if you still see P1001 in dev.
# Migrations: DIRECT_URL = non-pooler host (Prisma uses directUrl for migrate; see schema.prisma).
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ——— Cache (Upstash Redis) ———
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN=""


# Authentication
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"
# When true, register/login require email/SMS OTP before issuing JWT (see POST /api/v1/auth/verify).
AUTH_REQUIRE_VERIFICATION="false"

# Search: собственный поиск через Prisma (см. SEARCH-FUNCTION.md). Meilisearch не используется.
# MEILISEARCH_HOST / MEILISEARCH_API_KEY — удалены

# ——— Auth (Clerk) ———
#NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_..."
#CLERK_SECRET_KEY="sk_..."
#CLERK_WEBHOOK_SIGNING_SECRET=""
#NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
#NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"


# ——— Email (Resend) ———
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="test@neetrino.com"

# ——— File storage (Cloudflare R2) ———
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""
# Optional (Vercel build): comma-separated hostnames for next/image, e.g. custom R2 domain not matching *.r2.dev
# NEXT_IMAGE_REMOTE_HOSTS="cdn.shop.am"

# ——— Figma (MCP) ———
FIGMA_ACCESS_TOKEN=""

# ——— Payments (Idram / Armenian bank) ———
# Idram and bank gateway keys — add when integrating
# IDRAM_...
# BANK_...
# Generic PSP session + webhook integration (Phase 6)
# PAYMENT_PSP_PROVIDER="mock_psp"
# PAYMENT_PSP_CHECKOUT_BASE_URL="https://psp.example.com/checkout"
# PAYMENT_PSP_WEBHOOK_SECRET="replace-with-long-random-secret"
# PAYMENT_PSP_SESSION_TTL_MS="900000"

# ——— Contact form (POST /api/v1/contact) ———
# Optional: Cloudflare Turnstile — when set, clients must send `turnstileToken` in the JSON body.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=""   # widget (public)
# TURNSTILE_SECRET_KEY=""             # server verify (secret)
# Rate limiting: uses Upstash Redis when UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN are set;
# otherwise a per-process in-memory limiter applies (dev/single instance).

# ——— Database seed (`pnpm db:seed`) ———
# Creates/updates an admin user (bcrypt hash). Omit or leave empty to skip password reset for existing user.
# SEED_ADMIN_EMAIL=""
# SEED_ADMIN_PASSWORD=""

# ——— Optional ———
# When "true", only users with a non-cancelled order containing this product may POST a review (see reviews.service).
# REVIEW_REQUIRE_PURCHASE="false"
# SENTRY_DSN=""
# Google Maps / Mapbox for Contact page
# MAPBOX_PUBLIC_KEY=""
